WEBUI_SECRET_KEY=change-me-in-production

# Create an instance at https://demo.pocket-id.org, then replace the placeholder
# below with the generated subdomain. Do not include /setup or a trailing slash.
POCKET_ID_ISSUER_URL=https://replace-with-your-demo-id.demo.pocket-id.org
POCKET_ID_JWKS_URL=https://replace-with-your-demo-id.demo.pocket-id.org/.well-known/jwks.json
POCKET_ID_SIGNING_ALGS=RS256

# Open WebUI and the MCP server share this Docker-network resource identifier.
MCP_RESOURCE_URL=http://mcp:8080/mcp
MCP_OAUTH_SCOPES=notes:read notes:write
